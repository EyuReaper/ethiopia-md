---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — [Amharic translation needed - original Taiwan context] | Ethiopia.md">
  <main class="error-page">
    <div class="error-content">
      <h1 class="error-code">404</h1>
      <p class="error-title">[Amharic translation needed - original Taiwan context]</p>
      <p class="error-desc">[Amharic translation needed - original Taiwan context]、[Amharic translation needed - original Taiwan context]，[Amharic translation needed - original Taiwan context]。</p>

      <div class="error-actions">
        <a href="/" class="btn btn-primary">← [Amharic translation needed - original Taiwan context]</a>
        <a href="/graph" class="btn btn-secondary">🕸️ [Amharic translation needed - original Taiwan context]</a>
      </div>

      <div class="search-section">
        <p>[Amharic translation needed - original Taiwan context]：</p>
        <form
          action="https://www.google.com/search"
          method="get"
          target="_blank"
          class="search-form"
        >
          <input type="hidden" name="q" value="site:ethiopia.md" />
          <input
            type="text"
            name="q"
            placeholder="[Amharic translation needed - original Taiwan context] Ethiopia.md..."
            class="search-input"
            aria-label="[Amharic translation needed - original Taiwan context] Ethiopia.md"
          />
          <button type="submit" class="btn btn-primary">[Amharic translation needed - original Taiwan context]</button>
        </form>
      </div>

      <div class="report-section">
        <p class="report-title">🐛 [Amharic translation needed - original Taiwan context] Bug [Amharic translation needed - original Taiwan context]？</p>
        <p class="report-desc">
          [Amharic translation needed - original Taiwan context]，[Amharic translation needed - original Taiwan context]：
        </p>
        <a
          href={`https://github.com/frank890417/ethiopia-md/issues/new?template=broken-link.yml&title=404:+${encodeURIComponent('[[Amharic translation needed - original Taiwan context]]')}&labels=bug,broken-link`}
          class="btn btn-report"
          target="_blank"
          rel="noopener"
        >
          📋 [Amharic translation needed - original Taiwan context] (GitHub Issue)
        </a>
      </div>

      <div class="explore-section">
        <p>[Amharic translation needed - original Taiwan context]：</p>
        <div class="category-chips">
          <a href="/history">📜 [Amharic translation needed - original Taiwan context]</a>
          <a href="/culture">🎭 [Amharic translation needed - original Taiwan context]</a>
          <a href="/food">🧋 [Amharic translation needed - original Taiwan context]</a>
          <a href="/art">🎨 [Amharic translation needed - original Taiwan context]</a>
          <a href="/music">🎵 [Amharic translation needed - original Taiwan context]</a>
          <a href="/technology">💻 [Amharic translation needed - original Taiwan context]</a>
          <a href="/nature">🌿 [Amharic translation needed - original Taiwan context]</a>
          <a href="/people">👥 [Amharic translation needed - original Taiwan context]</a>
          <a href="/economy">📈 [Amharic translation needed - original Taiwan context]</a>
          <a href="/society">⚖️ [Amharic translation needed - original Taiwan context]</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Auto-fill the issue title with the current URL
  const reportLink = document.querySelector('.btn-report');
  if (reportLink) {
    const currentPath = window.location.pathname;
    const href = reportLink.getAttribute('href');
    reportLink.setAttribute(
      'href',
      href.replace(
        encodeURIComponent('[[Amharic translation needed - original Taiwan context]]'),
        encodeURIComponent(currentPath),
      ),
    );
  }

  // Fix Google search form — combine site: prefix with user query
  const form = document.querySelector('.search-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      const inputs = form.querySelectorAll('input[name="q"]');
      if (inputs.length === 2) {
        const sitePrefix = inputs[0].value; // "site:ethiopia.md"
        const userQuery = inputs[1].value.trim();
        if (userQuery) {
          inputs[0].value = `${sitePrefix} ${userQuery}`;
          inputs[1].removeAttribute('name'); // prevent duplicate param
        }
      }
    });
  }
</script>

<style>
  .error-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem var(--space-page-x);
  }

  .error-content {
    max-width: 600px;
    text-align: center;
  }

  .error-code {
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 900;
    color: #1a1a2e;
    margin: 0;
    line-height: 1;
    opacity: 0.15;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0.5rem 0;
    font-family: var(--font-editorial);
  }

  .error-desc {
    color: #666;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.95rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: #1a1a2e;
    color: white;
  }
  .btn-primary:hover {
    background: #2d2d4a;
  }

  .btn-secondary {
    background: #f0f0f0;
    color: #333;
  }
  .btn-secondary:hover {
    background: #e0e0e0;
  }

  .search-section {
    margin-bottom: 2.5rem;
  }
  .search-section p {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .search-input {
    padding: 0.5rem 1rem;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 0.95rem;
    width: 280px;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: #1a1a2e;
  }

  .report-section {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  .report-title {
    font-weight: 700;
    margin: 0 0 0.4rem 0;
    font-size: 1rem;
  }
  .report-desc {
    color: #666;
    font-size: 0.88rem;
    margin: 0 0 1rem 0;
  }

  .btn-report {
    background: #f59e0b;
    color: white;
    font-size: 0.9rem;
  }
  .btn-report:hover {
    background: #d97706;
  }

  .explore-section p {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .category-chips a {
    padding: 0.35rem 0.75rem;
    background: #f5f5f5;
    border-radius: 20px;
    font-size: 0.85rem;
    text-decoration: none;
    color: #333;
    transition: all 0.2s;
  }
  .category-chips a:hover {
    background: #1a1a2e;
    color: white;
  }

  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
    .search-form {
      flex-direction: column;
      align-items: center;
    }
    .search-input {
      width: 100%;
    }
  }
</style>
