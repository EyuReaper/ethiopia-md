<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('mini-graph');
    if (container) {
      const categories = [
        { id: 'history', name: '[Amharic translation needed - original Taiwan context]', color: '#dc2626' },
        { id: 'geography', name: '[Amharic translation needed - original Taiwan context]', color: '#2563eb' },
        { id: 'culture', name: '[Amharic translation needed - original Taiwan context]', color: '#7c3aed' },
        { id: 'food', name: '[Amharic translation needed - original Taiwan context]', color: '#ea580c' },
        { id: 'art', name: '[Amharic translation needed - original Taiwan context]', color: '#db2777' },
        { id: 'music', name: '[Amharic translation needed - original Taiwan context]', color: '#4f46e5' },
        { id: 'technology', name: '[Amharic translation needed - original Taiwan context]', color: '#0891b2' },
        { id: 'nature', name: '[Amharic translation needed - original Taiwan context]', color: '#16a34a' },
        { id: 'people', name: '[Amharic translation needed - original Taiwan context]', color: '#ca8a04' },
        { id: 'society', name: '[Amharic translation needed - original Taiwan context]', color: '#64748b' },
        { id: 'economy', name: '[Amharic translation needed - original Taiwan context]', color: '#0d9488' },
        { id: 'lifestyle', name: '[Amharic translation needed - original Taiwan context]', color: '#f97316' },
      ];

      const nodes = [
        {
          id: 'ethiopia',
          name: 'Ethiopia.md',
          size: 18,
          color: '#2d5016',
          group: 'core',
        },
        ...categories.map((c) => ({
          id: c.id,
          name: c.name,
          size: 12,
          color: c.color,
          group: 'category',
        })),
      ];

      const edges = categories.map((c) => ({ source: 'ethiopia', target: c.id }));
      const crossLinks = [
        ['history', 'people'],
        ['history', 'society'],
        ['culture', 'art'],
        ['culture', 'music'],
        ['food', 'lifestyle'],
        ['technology', 'economy'],
        ['nature', 'geography'],
        ['people', 'art'],
        ['society', 'economy'],
        ['music', 'culture'],
        ['lifestyle', 'food'],
        ['geography', 'nature'],
      ];
      crossLinks.forEach(([source, target]) => edges.push({ source, target }));

      const width = container.clientWidth;
      const height = 300;

      const svg = d3
        .select('#mini-graph')
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('preserveAspectRatio', 'xMidYMid meet');

      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(edges)
            .id((d) => d.id)
            .distance(60),
        )
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force(
          'collision',
          d3.forceCollide().radius((d) => d.size + 4),
        );

      const link = svg
        .append('g')
        .selectAll('line')
        .data(edges)
        .join('line')
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.5);

      const node = svg
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => d.size)
        .attr('fill', (d) => d.color)
        .attr('fill-opacity', 0.85)
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);

      const label = svg
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.name)
        .attr('text-anchor', 'middle')
        .attr('dy', (d) => d.size + 14)
        .attr('font-size', (d) => (d.group === 'core' ? '11px' : '9px'))
        .attr('font-weight', (d) => (d.group === 'core' ? '700' : '500'))
        .attr('fill', '#374151')
        .attr('pointer-events', 'none');

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }
  });
</script>

